@model IEnumerable<FoodInspectionApp.Models.Inspection>

@{
    ViewData["Title"] = "Inspections";
}

<div class="container mt-4">

    <div class="card shadow-lg rounded-3">
        <div class="card-header bg-dark text-white d-flex justify-content-between">
            <h4 class="mb-0">Inspections</h4>
            <a asp-action="Create" class="btn btn-success btn-sm">+ New Inspection</a>
        </div>

        <div class="card-body">

            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Premises</th>
                        <th>Date</th>
                        <th>Score</th>
                        <th>Outcome</th>
                        <th>Notes</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Premises?.Name</td>
                            <td>@item.InspectionDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.Score</td>

                            <td>
                                @if (item.Outcome == "Fail")
                                {
                                    <span class="badge bg-danger">Fail</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Pass</span>
                                }
                            </td>

                            <td>@item.Notes</td>

                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>