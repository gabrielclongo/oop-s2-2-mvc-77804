@model IEnumerable<FoodInspectionApp.Models.FollowUp>

@{
    ViewData["Title"] = "FollowUps";
}

<div class="container mt-4">

    <div class="card shadow-lg rounded-3">
        <div class="card-header bg-dark text-white d-flex justify-content-between">
            <h4 class="mb-0">Follow Ups</h4>
            <a asp-action="Create" class="btn btn-success btn-sm">+ New FollowUp</a>
        </div>

        <div class="card-body">

            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Inspection</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th>Closed Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.InspectionId</td>

                            <td>@item.DueDate.ToString("dd/MM/yyyy")</td>

                            <td>
                                @if (item.Status == "Open")
                                {
                                    <span class="badge bg-warning text-dark">Open</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Closed</span>
                                }
                            </td>

                            <td>
                                @(item.ClosedDate.HasValue
                                                            ? item.ClosedDate.Value.ToString("dd/MM/yyyy")
                                                            : "-")
                            </td>

                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>