@model FoodInspectionApp.Models.DashboardViewModel

<div class="container mt-4">

    <h2 class="mb-4">📊 Dashboard</h2>

    <!-- CARDS -->
    <div class="row">

        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3 shadow">
                <div class="card-body">
                    <h5>Total Inspections</h5>
                    <h2>@Model.TotalInspections</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-danger mb-3 shadow">
                <div class="card-body">
                    <h5>Failed Inspections</h5>
                    <h2>@Model.FailedInspections</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-warning mb-3 shadow">
                <div class="card-body">
                    <h5>Overdue FollowUps</h5>
                    <h2>@Model.OverdueFollowUps</h2>
                </div>
            </div>
        </div>

    </div>

    <!-- FILTER -->
    <div class="card p-3 shadow mt-4">
        <form method="get" class="row g-2">

            <div class="col-md-4">
                <select name="town" class="form-select">
                    <option value="">All Towns</option>
                    @foreach (var t in Model.Towns)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <select name="risk" class="form-select">
                    <option value="">All Risk Levels</option>
                    @foreach (var r in Model.RiskRatings)
                    {
                        <option value="@r">@r</option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <button class="btn btn-dark w-100">Filter</button>
            </div>

        </form>
    </div>

</div>